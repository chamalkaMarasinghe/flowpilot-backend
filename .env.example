PORT=5000
MONGODB_URI=mongodb://127.0.0.1:27017/flowpilot
JWT_SECRET=change-me-in-production
JWT_EXPIRES_IN=7d
CORS_ORIGIN=http://localhost:8080
NODE_ENV=development

# Required on Vercel (use MongoDB Atlas, not localhost):
# MONGODB_URI=mongodb+srv://user:pass@cluster.mongodb.net/flowpilot
# JWT_SECRET=your-strong-production-secret
# CORS_ORIGIN=https://your-frontend.vercel.app

# Optional: override auto-detected base URL (Vercel sets VERCEL_URL automatically)
# API_BASE_URL=https://your-app.vercel.app
